# .env — Self-Healing Code Reviewer
# Copy this to .env and fill in your keys before running

# ── LLM API Keys ──────────────────────────────────────────────────
OPENAI_API_KEY=       # GPT-4o (bug analysis + judge)
ANTHROPIC_API_KEY=   # Claude 3.5 Sonnet (fix writer)
TAVILY_API_KEY=         # Tavily (codebase search)

# ── GitHub ────────────────────────────────────────────────────────
GITHUB_TOKEN=  # Needs: repo, pull_request, issues scopes
GITHUB_WEBHOOK_SECRET=        # Any random string — set same in GitHub settings

# ── Pipeline behaviour ────────────────────────────────────────────
MAX_FIX_ATTEMPTS=3             # How many times Claude retries before giving up
HUMAN_IN_THE_LOOP=True        # Set to true to pause and ask for human approval before opening PR
